@page "/"
@using BlazorMurals.Shared.Models
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<PageTitle>Home</PageTitle>

<div id="home" class="container py-5 revealable">
    <!-- Artist Bio -->
    <section id="artist" class="artist-bio mb-5">
        <div class="row align-items-center g-4">
            <div class="col-12 col-md-4 text-center">
                <img src="https://picsum.photos/seed/artist/400/400" alt="Artist photo" class="rounded-circle img-fluid artist-photo" />
            </div>

            <div class="col-12 col-md-8">
                <h2 class="mb-2">Artist Name</h2>
                <p class="lead mb-3">
                    This is a short artist bio. Describe the artist's background, style, influences and a short statement
                    about their work. Keep it concise and engaging so visitors quickly understand the artist's voice.
                </p>

                <div class="social-links d-flex gap-3">
                    <a class="social-link" href="https://twitter.com/" target="_blank" rel="noopener" aria-label="Twitter">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 5.92c-.63.28-1.3.47-2 .56.72-.43 1.28-1.1 1.54-1.9-.67.4-1.4.7-2.18.86C18.7 4.3 17.6 4 16.43 4c-1.86 0-3.36 1.5-3.36 3.35 0 .26.03.51.08.75C9.7 8.02 6.1 6.1 3.9 3.14c-.29.5-.46 1.08-.46 1.7 0 1.17.6 2.2 1.52 2.8-.56-.02-1.08-.17-1.54-.43v.04c0 1.62 1.15 2.98 2.67 3.29-.28.08-.58.12-.88.12-.22 0-.44-.02-.65-.06.44 1.37 1.72 2.36 3.23 2.39-1.18.93-2.66 1.5-4.27 1.5-.28 0-.56-.02-.83-.05 1.53.98 3.35 1.55 5.3 1.55 6.36 0 9.85-5.27 9.85-9.84v-.45c.68-.5 1.26-1.12 1.72-1.83-.63.28-1.32.48-2.03.56z" fill="currentColor"/></svg>
                    </a>

                    <a class="social-link" href="https://instagram.com/" target="_blank" rel="noopener" aria-label="Instagram">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 6a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm6.5-3a1.2 1.2 0 1 0 0 2.4A1.2 1.2 0 0 0 18.5 5z" fill="currentColor"/></svg>
                    </a>

                    <a class="social-link" href="https://facebook.com/" target="_blank" rel="noopener" aria-label="Facebook">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.5 9.9v-7H8.9v-2.9h1.6V9.4c0-1.6 1-2.5 2.4-2.5.7 0 1.4.05 2 .1v2.3h-1.2c-1 0-1.3.6-1.3 1.2v1.5h2.3l-.37 2.9h-1.95v7A10 10 0 0 0 22 12z" fill="currentColor"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Album gallery on homepage -->
    <section id="gallery" class="album-gallery revealable">
        <h3 class="mb-3">Featured Albums</h3>

        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3 gallery-grid">
            @foreach (var album in Albums)
            {
                <div class="col">
                    <div class="card album-card h-100" role="button"
                         @onclick="async () => await OpenAlbum(album)"
                         @onkeydown="(e => OnAlbumKey(e, album))"
                         tabindex="0"
                         aria-label="@($"Open album {album.Title}")">
                        <div class="thumbnail-wrapper">
                            <img src="@album.CoverUrl" class="card-img-top thumbnail-img" alt="@album.Title" loading="lazy" />
                        </div>
                        <div class="card-body py-2">
                            <h6 class="card-title mb-0 text-truncate">@album.Title</h6>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Contact section -->
    <section id="contact" class="contact-section mt-5 revealable">
        <h3>Contact Us</h3>
        <p>If you'd like to commission or inquire, reach out using the form or by email below.</p>

        <div class="row">
            <div class="col-md-6">
                <form onsubmit="return false;">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message</label>
                        <textarea class="form-control" rows="5"></textarea>
                    </div>
                    <button class="btn btn-primary" type="button">Send</button>
                </form>
            </div>

            <div class="col-md-6">
                <h6>Contact</h6>
                <p><strong>Email:</strong> artist@example.com</p>
                <p><strong>Phone:</strong> (555) 123-4567</p>
            </div>
        </div>
    </section>
</div>

<AlbumCarousel Album="SelectedAlbum" Visible="ShowCarousel" OnClose="CloseCarousel" />

@code {
    private List<Album> Albums = new();
    private Album? SelectedAlbum;
    private bool ShowCarousel;

    protected override void OnInitialized()
    {
        Albums = new List<Album>
        {
            new Album { Id = "a1", Title = "Vibrant Murals", CoverUrl = "https://picsum.photos/seed/mural1/600/400", Images = new List<string>{ "https://picsum.photos/seed/mural1-1/1200/800", "https://picsum.photos/seed/mural1-2/1200/800" } },
            new Album { Id = "a2", Title = "Street Pieces", CoverUrl = "https://picsum.photos/seed/street1/600/400", Images = new List<string>{ "https://picsum.photos/seed/street1-1/1200/800", "https://picsum.photos/seed/street1-2/1200/800" } },
            new Album { Id = "a3", Title = "Abstract Walls", CoverUrl = "https://picsum.photos/seed/abstract1/600/400", Images = new List<string>{ "https://picsum.photos/seed/abstract1-1/1200/800", "https://picsum.photos/seed/abstract1-2/1200/800" } }
        };
    }

    private async Task OpenAlbum(Album album)
    {
        SelectedAlbum = album;
        ShowCarousel = true;
        await InvokeAsync(StateHasChanged);
    }

    private Task CloseCarousel()
    {
        ShowCarousel = false;
        SelectedAlbum = null;
        return Task.CompletedTask;
    }

    private async Task OnAlbumKey(KeyboardEventArgs e, Album album)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            await OpenAlbum(album);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // If the URL contains a fragment (e.g. /#gallery), scroll to it after load
            var uri = new Uri(NavigationManager.Uri);
            if (!string.IsNullOrEmpty(uri.Fragment))
            {
                var id = uri.Fragment.TrimStart('#');
                // fixed: use 'site' (matches wwwroot/js/site.js)
                await JS.InvokeVoidAsync("site.scrollToId", id);
            }

            // initialize reveal observer - use 'site'
            await JS.InvokeVoidAsync("site.initRevealObserver");
        }

        await base.OnAfterRenderAsync(firstRender);
    }
}
