@page "/gallery"
@using BlazorMurals.Shared.Models
@using System.Linq
@inject HttpClient Http

<PageTitle>Gallery</PageTitle>

<h1 class="mb-3">Artwork Gallery</h1>

<AlbumGallery Albums="Albums" OnAlbumSelected="OpenAlbum" />

<AlbumCarousel Album="SelectedAlbum" Visible="ShowCarousel" OnClose="CloseCarousel" />

@code {
    private List<Album> Albums = new();
    private Album? SelectedAlbum;
    private bool ShowCarousel;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await Http.GetFromJsonAsync<GalleryData>("galleryData.json");
            if (data?.Albums != null)
            {
                Albums = data.Albums.Select(a => new Album
                {
                    Id = a.Id,
                    Title = a.Title,
                    Thumbnail = a.Thumbnail ?? string.Empty,
                    Images = a.Images
                }).ToList();
            }
        }
        catch
        {
            Albums = new();
        }
    }

    private Task OpenAlbum(Album album)
    {
        SelectedAlbum = album;
        ShowCarousel = true;
        return Task.CompletedTask;
    }

    private Task CloseCarousel()
    {
        ShowCarousel = false;
        SelectedAlbum = null;
        return Task.CompletedTask;
    }
}