@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<nav class="navbar navbar-expand-md top-navbar" role="navigation" aria-label="Main navigation">
    <div class="container-fluid">
        <button type="button" class="navbar-brand btn btn-link p-0 m-0" @onclick='() => JumpToSection("home")' aria-label="Go to home">BlazorMurals</button>

        <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu"
                aria-label="Toggle navigation" aria-expanded="@((!collapseNavMenu).ToString().ToLowerInvariant())" aria-controls="navbarSupportedContent">
            <svg class="toggler-icon" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <rect x="3" y="6" width="18" height="2" rx="1" fill="currentColor" />
                <rect x="3" y="11" width="18" height="2" rx="1" fill="currentColor" />
                <rect x="3" y="16" width="18" height="2" rx="1" fill="currentColor" />
            </svg>
        </button>

        <div id="navbarSupportedContent" class="@NavMenuCssClass">
            <ul class="navbar-nav ms-auto nav-uniform">
                <li class="nav-item">
                    <button type="button" class="nav-link btn-link" @onclick='() => JumpToSection("home")'>Home</button>
                </li>

                <li class="nav-item">
                    <button type="button" class="nav-link btn-link" @onclick='() => JumpToSection("gallery")'>Gallery</button>
                </li>

                <li class="nav-item">
                    <button type="button" class="nav-link btn-link" @onclick='() => JumpToSection("contact")'>Contact</button>
                </li>

                <li class="nav-item theme-item-wrapper">
                    <button type="button" class="btn theme-toggle" @onclick="ToggleTheme" title="Toggle light / dark theme"
                            aria-pressed="@IsDark.ToString().ToLowerInvariant()" aria-label="Toggle theme">
                        @if (IsDark)
                        {
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="currentColor" /></svg>
                        }
                        else
                        {
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6.76 4.84l-1.8-1.79L3.17 4.84l1.79 1.79 1.8-1.79zM1 13h3v-2H1v2zm10 9h2v-3h-2v3zM6.76 19.16l1.79-1.79-1.79-1.8L4.97 17.36l1.79 1.8zM20 11v2h3v-2h-3zM13 1h-2v3h2V1zm6.04 3.05l-1.79 1.79 1.79 1.8 1.79-1.8L19.04 4.05z" fill="currentColor" /></svg>
                        }
                    </button>
                </li>
            </ul>
        </div>
    </div>
</nav>

@code {
    private bool collapseNavMenu = true;
    private bool IsDark { get; set; }

    private string NavMenuCssClass => collapseNavMenu ? "collapse navbar-collapse" : "collapse navbar-collapse show";

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    private void CollapseMenu()
    {
        if (!collapseNavMenu)
        {
            collapseNavMenu = true;
            StateHasChanged();
        }
    }

    private async Task JumpToSection(string id)
    {
        CollapseMenu();
        var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Split('?')[0];
        if (string.IsNullOrEmpty(relative))
        {
            try { await JS.InvokeVoidAsync("site.scrollToId", id); }
            catch { NavigationManager.NavigateTo($"/#{id}"); }
        }
        else
        {
            NavigationManager.NavigateTo($"/#{id}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("eval", "localStorage.getItem('theme') || document.documentElement.getAttribute('data-theme') || (document.documentElement.classList.contains('theme-dark') ? 'dark' : 'light')");
            if (string.IsNullOrEmpty(theme)) theme = "light";
            IsDark = theme.Equals("dark", StringComparison.OrdinalIgnoreCase);
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        var newTheme = IsDark ? "light" : "dark";
        await JS.InvokeVoidAsync("site.setTheme", newTheme);
        IsDark = !IsDark;
        StateHasChanged();
    }
}