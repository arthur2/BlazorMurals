@using BlazorMurals.Shared.Models
@using Microsoft.AspNetCore.Components.Web

@if (isRendered && Album is not null && Album.Images?.Count > 0)
{
  <div class="carousel-overlay @overlayClass" @onkeydown="HandleKey" tabindex="0" @ref="overlayRef">
    <div class="carousel-container">
      <div class="d-flex justify-content-end mb-2">
        <button class="btn btn-close btn-close-white" @onclick="Close" aria-label="Close"></button>
      </div>

      <div class="carousel-stage">
        <button class="carousel-control" @onclick="Previous" aria-label="Previous">‹</button>

        <div class="flex-grow-1 text-center">
          <img src="@CurrentImagePath" alt="@CurrentImageTitle" class="carousel-image @imageClass" />
          <div class="mt-2 text-muted small">@($"{CurrentIndex + 1} / {Album.Images.Count}")</div>
        </div>

        <button class="carousel-control" @onclick="Next" aria-label="Next">›</button>
      </div>

      <div class="carousel-caption">
        <h3>@CurrentImageTitle</h3>
        <p>@CurrentImageDescription</p>
      </div>

      <div class="carousel-thumbs">
        @for (int i = 0; i < Album.Images.Count; i++)
        {
            var idx = i; <!-- capture loop variable -->
            <img src="@Album.Images[idx].Thumbnail" class="@(idx == CurrentIndex ? "active" : "")" @onclick="() => GoTo(idx)" alt="@Album.Images[idx].Title" loading="lazy" />
        }
      </div>
    </div>
  </div>
}

@code {
  [Parameter] public Album? Album { get; set; }
  [Parameter] public bool Visible { get; set; }
  [Parameter] public EventCallback OnClose { get; set; }

  private int CurrentIndex { get; set; }
  private ElementReference overlayRef;
  private bool focusPending;

  // Rendering / animation state
  private bool isRendered;
  private string overlayClass = string.Empty; // "overlay-visible" | "overlay-hidden"
  private string imageClass = string.Empty;   // e.g. "fade-in zoom" | "fade-out"

  // animation durations (match CSS)
  private readonly int overlayMs = 280;
  private readonly int imageMs = 260;

  private string CurrentImagePath => Album?.Images?.Count > 0 ? Album.Images[CurrentIndex].ImagePath : string.Empty;
  private string CurrentImageTitle => Album?.Images?.Count > 0 ? Album.Images[CurrentIndex].Title : string.Empty;
  private string CurrentImageDescription => Album?.Images?.Count > 0 ? Album.Images[CurrentIndex].Description : string.Empty;

  protected override async Task OnParametersSetAsync()
  {
    if (Visible && Album is not null && Album.Images?.Count > 0)
    {
      // show: ensure rendered, reset index and run enter animation
      if (!isRendered)
      {
        isRendered = true;
        CurrentIndex = 0;
        overlayClass = "overlay-visible";
        imageClass = "fade-in zoom"; // start with zoom enabled
        focusPending = true;
        StateHasChanged();
        await Task.Delay(imageMs);
        imageClass = "zoom"; // keep zoom running after fade-in completes
      }
      else
      {
        // album already rendered: ensure zoom running for current image
        imageClass = "zoom";
      }
    }
    else if (!Visible && isRendered)
    {
      // hide: start overlay leave animation then stop rendering
      overlayClass = "overlay-hidden";
      StateHasChanged();
      await Task.Delay(overlayMs);
      isRendered = false;
      overlayClass = string.Empty;
      imageClass = string.Empty;
    }
  }

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (focusPending && isRendered)
    {
      focusPending = false;
      try { await overlayRef.FocusAsync(); } catch { }
    }
    await base.OnAfterRenderAsync(firstRender);
  }

  private Task Close() => OnClose.InvokeAsync();

  private Task Previous() => SwitchToIndexAsync((CurrentIndex - 1 + (Album?.Images.Count ?? 1)) % (Album?.Images.Count ?? 1));
  private Task Next() => SwitchToIndexAsync((CurrentIndex + 1) % (Album?.Images.Count ?? 1));

  private Task GoTo(int idx) => SwitchToIndexAsync(idx);

  private async Task SwitchToIndexAsync(int newIndex)
  {
    if (Album == null || Album.Images.Count == 0) return;
    newIndex = Math.Clamp(newIndex, 0, Album.Images.Count - 1);
    if (newIndex == CurrentIndex) return;

    // fade out current image and stop zoom
    imageClass = "fade-out";
    StateHasChanged();
    await Task.Delay(imageMs);

    // swap image and fade in with zoom
    CurrentIndex = newIndex;
    imageClass = "fade-in zoom";
    StateHasChanged();
    await Task.Delay(imageMs);

    // leave zoom running
    imageClass = "zoom";
    StateHasChanged();
  }

  private async Task HandleKey(KeyboardEventArgs e)
  {
    if (!Visible) return;
    if (e.Key == "ArrowLeft") await Previous();
    else if (e.Key == "ArrowRight") await Next();
    else if (e.Key == "Escape") await Close();
  }
}